APP_NAME=Agent Orchestration System
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql+psycopg://agent:agent@postgres:5432/agent_orchestration

OTEL_SERVICE_NAME=agent-orchestration-system
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_ENABLED=false

DEFAULT_REASONING_MODEL=claude-sonnet
DEFAULT_CHEAP_MODEL=gpt-4o-mini
